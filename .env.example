# Public site URL (used for canonical URLs, OG tags, sitemap, robots).
NEXT_PUBLIC_SITE_URL=https://inspireafricans.com

# Strapi connection (server-side fetches).
STRAPI_BASE_URL=http://localhost:1337
STRAPI_PUBLIC_TOKEN=
REVALIDATE_SECRET=

# Visitor analytics — server-side ingest proxy → CMS collect endpoint.
# ANALYTICS_INGEST_TOKEN must match the value set on the CMS.
ANALYTICS_INGEST_URL=http://localhost:1337/api/analytics/collect
ANALYTICS_INGEST_TOKEN=
