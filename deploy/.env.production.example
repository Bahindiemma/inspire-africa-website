# ============================================================
# INSPIRE AFRICA — production environment for docker-compose
# Copy to `.env` (same folder as docker-compose.yml) and fill in.
# NEVER commit the real .env.
# ============================================================

# ---------- Public URLs (bare IP, HTTP) ----------
SITE_URL=http://37.60.225.220
CMS_PUBLIC_URL=http://37.60.225.220:1337
# Browser origins allowed to call the Strapi API (comma-separated, never *).
CORS_ORIGINS=http://37.60.225.220,http://37.60.225.220:1337

# ---------- MySQL ----------
DATABASE_NAME=inspire_africa_cms
DATABASE_USERNAME=strapi
# Use strong, unique values. Generate with: openssl rand -base64 24
DATABASE_PASSWORD=CHANGE_ME_db_password
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password

# ---------- Strapi secrets ----------
# Generate EACH of these with: openssl rand -base64 32
# APP_KEYS must be 4 comma-separated values.
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=CHANGE_ME
ADMIN_JWT_SECRET=CHANGE_ME
TRANSFER_TOKEN_SALT=CHANGE_ME
JWT_SECRET=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

# ---------- Shared revalidation secret (CMS -> web webhook) ----------
REVALIDATE_SECRET=CHANGE_ME

# ---------- Public API token for the Next.js app ----------
# Leave blank for the FIRST boot. After Strapi is up, create a read-only
# API token in the admin (Settings -> API Tokens), paste it here, then
# `docker compose up -d web` to restart the site with the token.
STRAPI_PUBLIC_TOKEN=
